<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Honeycrisp sends Apple Events to Mail and Messages (send, save draft,
	     mark read). Under the hardened runtime that notarization requires,
	     this entitlement is what permits it; the user still grants the TCC
	     automation prompt at first use. -->
	<key>com.apple.security.automation.apple-events</key>
	<true/>
</dict>
</plist>
